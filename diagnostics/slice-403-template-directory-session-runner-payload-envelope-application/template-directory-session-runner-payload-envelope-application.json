              "created_paths": [
                ".env.local.example",
                "bin/setup.sh",
                "demo.gemspec"
              ],
              "updated_paths": [],
              "kept_paths": [
                "config/mise.toml"
              ],
              "blocked_paths": [
                "README.md"
              ],
              "omitted_paths": [
                ".kettle-jem.yml"
              ]
            },
            "run_report": null,
            "apply_report": null
          }
        },
        "status": {
          "mode": "plan",
          "ready": false,
          "missing_families": [
            "dotenv"
          ],
          "blocked_paths": [
            "README.md"
          ],
          "planned_write_count": 3,
          "written_count": 0
        },
        "diagnostics": {
          "mode": "plan",
          "ready": false,
          "diagnostics": [
            {
              "severity": "error",
              "category": "configuration_error",
              "reason": "missing_family_adapter",
              "path": ".env.local.example",
              "family": "dotenv",
              "message": "missing family adapter for dotenv blocks .env.local.example"
