{
  "name": "table_and_array",
  "dialect": "toml",
  "source": "title = \"Structured Merge\"\nenabled = true\ntags = [\"merge\", \"toml\"]\n\n[package]\nname = \"structuredmerge\"\nversion = \"0.1.0\"\n",
  "expected": {
    "root_kind": "table",
    "owners": [
      {
        "path": "/enabled",
        "owner_kind": "key_value",
        "match_key": "enabled"
      },
      {
        "path": "/package",
        "owner_kind": "table",
        "match_key": "package"
      },
      {
        "path": "/package/name",
        "owner_kind": "key_value",
        "match_key": "name"
      },
      {
        "path": "/package/version",
        "owner_kind": "key_value",
        "match_key": "version"
      },
      {
        "path": "/tags",
        "owner_kind": "key_value",
        "match_key": "tags"
      },
      {
        "path": "/tags/0",
        "owner_kind": "array_item"
      },
      {
        "path": "/tags/1",
        "owner_kind": "array_item"
      },
      {
        "path": "/title",
        "owner_kind": "key_value",
        "match_key": "title"
      }
    ]
  }
}
