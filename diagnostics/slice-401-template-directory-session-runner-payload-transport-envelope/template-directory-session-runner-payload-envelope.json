          },
          {
            "path": "config/mise.toml",
            "strategy": "keep_destination"
          },
          {
            "path": "bin/setup.sh",
            "strategy": "raw_copy"
          }
        ],
        "replacements": {
          "KJ|GEM_NAME": "demo",
