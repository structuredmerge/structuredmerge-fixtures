{
  "name": "object-and-array",
  "dialect": "json",
  "source": "{\n  \"name\": \"structuredmerge\",\n  \"tags\": [\"merge\", \"ast\"],\n  \"meta\": {\"enabled\": true}\n}\n",
  "expected": {
    "root_kind": "object",
    "owners": [
      {"path": "/meta", "owner_kind": "member", "match_key": "meta"},
      {"path": "/meta/enabled", "owner_kind": "member", "match_key": "enabled"},
      {"path": "/name", "owner_kind": "member", "match_key": "name"},
      {"path": "/tags", "owner_kind": "member", "match_key": "tags"},
      {"path": "/tags/0", "owner_kind": "element"},
      {"path": "/tags/1", "owner_kind": "element"}
    ]
  }
}
