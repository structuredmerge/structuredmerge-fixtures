        "owner_kind": "import",
        "match_key": "std::fmt::Display"
      },
      {
        "path": "/declarations/Greeter",
        "owner_kind": "declaration",
        "match_key": "Greeter"
      },
      {
        "path": "/declarations/greet",
        "owner_kind": "declaration",
        "match_key": "greet"
      }
    ]
  }
