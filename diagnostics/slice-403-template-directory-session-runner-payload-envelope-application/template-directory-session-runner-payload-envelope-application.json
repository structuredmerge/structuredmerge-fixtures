                ".env.local.example": "APP_ENV=development\n",
                "bin/setup.sh": "echo setup\n",
                "config/mise.toml": "project = \"existing\"\n",
                "demo.gemspec": "spec.name = \"demo\"\nspec.summary = \"Example gem summary\"\n"
